{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|png|jpg|ico|wav)",
        "headers": [
          {
            "key": "Cache-Control",
            "max-age": 31536000,
            "directive": "public"
          }
        ]
      },
      {
        "source": "sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "max-age": 0,
            "directive": "no-cache"
          }
        ]
      }
    ]
  }
}
